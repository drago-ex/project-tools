#!/usr/bin/env php
<?php

declare(strict_types=1);

$green = "\033[32m";
$yellow = "\033[33m";
$red = "\033[31m";
$reset = "\033[0m";

const ToolsExtraKey = 'drago-tools';
const DefaultVendorNames = ['drago-ex'];

$projectRoot = getcwd();
$rootComposerPath = $projectRoot . '/composer.json';

if (!is_file($rootComposerPath)) {
	echo "{$red}ERROR: composer.json not found in current directory.{$reset}\n";
	exit(1);
}

$rootComposer = json_decode((string) file_get_contents($rootComposerPath), true);
if (!is_array($rootComposer)) {
	echo "{$red}ERROR: composer.json is not valid JSON.{$reset}\n";
	exit(1);
}

function normalizeVendorNames(mixed $vendorNames): array
{
	if (is_string($vendorNames) && $vendorNames !== '') {
		return [$vendorNames];
	}

	if (!is_array($vendorNames)) {
		return DefaultVendorNames;
	}

	$normalized = [];
	foreach ($vendorNames as $vendorName) {
		if (is_string($vendorName) && $vendorName !== '') {
			$normalized[] = trim($vendorName, '/');
		}
	}

	return $normalized !== [] ? array_values(array_unique($normalized)) : DefaultVendorNames;
}

function deleteDir(string $dir): void
{
	if (!is_dir($dir)) {
		return;
	}

	$files = array_diff(scandir($dir), ['.', '..']);
	foreach ($files as $file) {
		$path = $dir . '/' . $file;
		is_dir($path) ? deleteDir($path) : unlink($path);
	}

	rmdir($dir);
}

$toolsConfig = $rootComposer['extra'][ToolsExtraKey] ?? [];
if (!is_array($toolsConfig)) {
	$toolsConfig = [];
}

$vendorNames = normalizeVendorNames($toolsConfig['vendor-names'] ?? DefaultVendorNames);

foreach ($vendorNames as $vendorName) {
	$vendorDir = $projectRoot . '/vendor/' . $vendorName;

	if (!is_dir($vendorDir)) {
		echo "{$yellow}WARN Vendor name not found: {$vendorName}{$reset}\n";
		continue;
	}

	foreach (glob($vendorDir . '/*', GLOB_ONLYDIR) as $packageDir) {
		$resourceDir = $packageDir . '/resources';
		if (is_dir($resourceDir)) {
			deleteDir($resourceDir);
			echo "{$green}DELETED:{$reset} $resourceDir\n";
		}
	}
}

echo "{$green}OK Done.{$reset}\n";
