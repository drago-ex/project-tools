#!/usr/bin/env php
<?php

declare(strict_types=1);

use Composer\InstalledVersions;

$blue = "\033[34m";
$green = "\033[32m";
$yellow = "\033[33m";
$red = "\033[31m";
$reset = "\033[0m";

// Try to find composer's autoload
$autoloadPaths = [
		getcwd() . '/vendor/autoload.php',
		__DIR__ . '/../../../autoload.php',
		__DIR__ . '/../vendor/autoload.php',
];

$autoloadFound = false;
foreach ($autoloadPaths as $path) {
	if (file_exists($path)) {
		require $path;
		$autoloadFound = true;
		break;
	}
}

if (!$autoloadFound) {
	die("{$red}ERROR: composer autoload.php not found. Run 'composer install' first.{$reset}\n");
}

$projectRoot = getcwd();

/**
 * PARAMETERS:
 * --verbose / -v : prints detailed information about copying
 * --dev          : switches the destination directory to resources/ for testing during package development
 */
$verbose = in_array('--verbose', $argv) || in_array('-v', $argv);
$isDevMode = in_array('--dev', $argv);

// If we are in dev mode, the target is not the project root, but the resources folder in the current package
$destinationRoot = $isDevMode ? $projectRoot . '/resources' : $projectRoot;

$stats = ['copied' => 0, 'skipped' => 0, 'errors' => 0];
$installOncePackages = [];
const ToolsExtraKey = 'drago-tools';
const ResourcePackageType = 'drago-tools-resource';
const DefaultVendorNames = ['drago-ex'];

function message(string $msg, string $icon = '', bool $force = false): void
{
	global $verbose;
	if ($verbose || $force) {
		echo $icon . ' ' . $msg . "\n";
	}
}

function ensureDir(string $dir): void
{
	if (!is_dir($dir) && !mkdir($dir, 0o777, true) && !is_dir($dir)) {
		throw new RuntimeException("Cannot create directory: $dir");
	}
}

function assertSafeRelativePath(string $path, string $label): void
{
	$normalized = str_replace('\\', '/', $path);
	if (
		$normalized === ''
		|| str_starts_with($normalized, '/')
		|| preg_match('~^[A-Za-z]:/~', $normalized) === 1
		|| in_array('..', explode('/', $normalized), true)
	) {
		throw new RuntimeException("Unsafe $label path: $path");
	}
}

function assertSafeVendorName(string $vendorName): void
{
	if (preg_match('~^[a-z0-9][a-z0-9._-]*$~', $vendorName) !== 1) {
		throw new RuntimeException("Unsafe vendor name: $vendorName");
	}
}

function copyFile(string $source, string $destination, bool $overwrite = false): void
{
	global $green, $reset, $stats, $yellow;

	$existsBefore = file_exists($destination);
	ensureDir(dirname($destination));

	if (!$overwrite && $existsBefore) {
		message($destination, "{$yellow}SKIP exists:{$reset}");
		$stats['skipped']++;
		return;
	}

	if (!copy($source, $destination)) {
		$stats['errors']++;
		throw new RuntimeException("Failed copying $source -> $destination");
	}

	$stats['copied']++;
	$icon = ($overwrite && $existsBefore)
			? "{$green}REPLACED:{$reset}"
			: "{$green}COPIED:{$reset}";
	message("$source -> $destination", $icon);
}

function recursiveCopy(string $source, string $destination, bool $overwrite = false): void
{
	$iterator = new RecursiveIteratorIterator(
			new RecursiveDirectoryIterator($source, FilesystemIterator::SKIP_DOTS),
			RecursiveIteratorIterator::SELF_FIRST
	);

	foreach ($iterator as $item) {
		$targetPath = $destination . '/' . substr($item->getPathname(), strlen($source) + 1);
		if ($item->isDir()) {
			ensureDir($targetPath);
		} else {
			copyFile($item->getPathname(), $targetPath, $overwrite);
		}
	}
}

function normalizeVendorNames(mixed $vendorNames): array
{
	if (is_string($vendorNames) && $vendorNames !== '') {
		return [$vendorNames];
	}

	if (!is_array($vendorNames)) {
		return DefaultVendorNames;
	}

	$normalized = [];
	foreach ($vendorNames as $vendorName) {
		if (is_string($vendorName) && $vendorName !== '') {
			$vendorName = trim($vendorName, '/');
			assertSafeVendorName($vendorName);
			$normalized[] = $vendorName;
		}
	}

	return $normalized !== [] ? array_values(array_unique($normalized)) : DefaultVendorNames;
}

function isAllowedVendor(string $packageName, array $vendorNames): bool
{
	foreach ($vendorNames as $vendorName) {
		if (str_starts_with($packageName, $vendorName . '/')) {
			return true;
		}
	}

	return false;
}

function warnMissingVendorNames(string $projectRoot, array $vendorNames): void
{
	global $yellow, $reset;

	foreach ($vendorNames as $vendorName) {
		if (!is_dir($projectRoot . '/vendor/' . $vendorName)) {
			echo "{$yellow}WARN Vendor name not found: {$vendorName}{$reset}\n";
		}
	}
}

function installPackageResources(
	string $packageName,
	string $packagePath,
	string $targetBaseDir,
	bool $allowLibraryInstall,
	array $packageOptions,
	?string $onlySection = null,
): void
{
	global $red, $reset, $stats, $installOncePackages;

	$composerPath = $packagePath . '/composer.json';
	if (!is_file($composerPath)) return;

	$composer = json_decode(file_get_contents($composerPath), true);
	$dragoConfig = $composer['extra'][ToolsExtraKey] ?? [];
	$install = $dragoConfig['install'] ?? [];
	$sections = ['copy' => false, 'replace' => true];

	$type = $composer['type'] ?? 'library';
	$hasInstallRules = !empty($install['copy']) || !empty($install['replace']);
	$isAllowedType = $type === ResourcePackageType || ($type === 'library' && $allowLibraryInstall);
	if ($hasInstallRules && !$isAllowedType) return;

	$hasReplace = !empty($install['replace']);
	$errorsBefore = $stats['errors'];

	foreach ($sections as $sectionName => $overwrite) {
		if ($onlySection !== null && $sectionName !== $onlySection) {
			continue;
		}

		if (($packageOptions['skip-' . $sectionName] ?? false) === true) {
			message("Skipping $sectionName section: $packageName", '[skip]', true);
			continue;
		}

		$items = $install[$sectionName] ?? null;
		if (!$items) continue;

		foreach ($items as $srcRel => $dstRel) {
			assertSafeRelativePath((string) $srcRel, 'source');
			if ($dstRel !== '') {
				assertSafeRelativePath((string) $dstRel, 'destination');
			}

			$source = $packagePath . '/' . $srcRel;

			if (!file_exists($source)) {
				message($source, "{$red}ERROR source not found:{$reset}");
				$stats['errors']++;
				continue;
			}

			$destination = $dstRel === ''
					? $targetBaseDir . '/' . basename($source)
					: $targetBaseDir . '/' . $dstRel;

			if (is_file($source)) {
				if (is_dir($destination) || (!pathinfo($destination, PATHINFO_EXTENSION) && !file_exists($destination))) {
					ensureDir($destination);
					$destination .= '/' . basename($source);
				}
				copyFile($source, $destination, $overwrite);

			} elseif (is_dir($source)) {
				recursiveCopy($source, $destination, $overwrite);
			}
		}
	}

	if (
		($onlySection === null || $onlySection === 'replace')
		&& isReplaceOnce($dragoConfig)
		&& $hasReplace
		&& $stats['errors'] === $errorsBefore
	) {
		$installOncePackages[] = $packageName;
	}
}

function isReplaceOnce(array $dragoConfig): bool
{
	$installConfig = $dragoConfig['install'] ?? [];
	return (bool) ($installConfig['replace-once'] ?? false);
}

function getPackageReplacePriority(string $packagePath): int
{
	$composerPath = $packagePath . '/composer.json';
	if (!is_file($composerPath)) {
		return 100;
	}

	$composer = json_decode(file_get_contents($composerPath), true);
	$dragoConfig = $composer['extra'][ToolsExtraKey] ?? [];
	$installConfig = $dragoConfig['install'] ?? [];
	return (int) ($installConfig['replace-priority'] ?? 100);
}

function writeRootComposer(string $rootComposerPath, array $rootComposer): void
{
	$json = json_encode($rootComposer, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE);
	if ($json === false) {
		throw new RuntimeException('Cannot encode root composer.json.');
	}

	file_put_contents($rootComposerPath, $json . "\n");
}

function markInstallOncePackages(string $rootComposerPath, array $rootComposer, array $packageNames): void
{
	if ($packageNames === []) {
		return;
	}

	$changed = false;
	foreach (array_unique($packageNames) as $packageName) {
		$current = $rootComposer['extra'][ToolsExtraKey]['packages'][$packageName]['skip-replace'] ?? false;
		if ($current === true) {
			continue;
		}

		$rootComposer['extra'][ToolsExtraKey]['packages'][$packageName]['skip-replace'] = true;
		$changed = true;
		message("Marked package replace section as install-once: $packageName", '[once]', true);
	}

	if ($changed) {
		writeRootComposer($rootComposerPath, $rootComposer);
	}
}

// ----------------------------
// ROOT CONFIG
// ----------------------------
$rootComposerPath = $projectRoot . '/composer.json';
if (!file_exists($rootComposerPath)) {
	die("{$red}ERROR: composer.json not found in current directory.{$reset}\n");
}

$rootComposer = json_decode((string) file_get_contents($rootComposerPath), true);
if (!is_array($rootComposer)) {
	die("{$red}ERROR: composer.json is not valid JSON.{$reset}\n");
}

$dragoConfig = $rootComposer['extra'][ToolsExtraKey] ?? [];
$allowLibraryInstall = $dragoConfig['allow-library-install'] ?? false;
$packageConfig = $dragoConfig['packages'] ?? [];
$vendorNames = normalizeVendorNames($dragoConfig['vendor-names'] ?? DefaultVendorNames);
warnMissingVendorNames($projectRoot, $vendorNames);

$rootPackageName = InstalledVersions::getRootPackage()['name'] ?? null;

if ($isDevMode) {
	message("Dev mode active: redirecting output to $destinationRoot", "{$blue}DEV:{$reset}", true);
}

// ----------------------------
// MAIN LOOP
// ----------------------------
$packages = [];
foreach (InstalledVersions::getInstalledPackages() as $packageName) {

	// Skip root package
	if ($packageName === $rootPackageName) {
		continue;
	}

	if (!isAllowedVendor($packageName, $vendorNames)) {
		continue;
	}

	// Skip packages via composer.json config
	if (($packageConfig[$packageName]['skip'] ?? false) === true) {
		message("Skipping package (config): $packageName", '[skip]', true);
		continue;
	}

	$packagePath = InstalledVersions::getInstallPath($packageName);
	if (!$packagePath) {
		continue;
	}

	$packages[] = [
		'name' => $packageName,
		'path' => $packagePath,
		'priority' => getPackageReplacePriority($packagePath),
	];
}

foreach ($packages as $package) {
	try {
		installPackageResources(
			$package['name'],
			$package['path'],
			$destinationRoot,
			$allowLibraryInstall,
			$packageConfig[$package['name']] ?? [],
			'copy',
		);

	} catch (Throwable $e) {
		message("Error in {$package['name']}: " . $e->getMessage(), "{$red}ERROR:{$reset}", true);
		continue;
	}
}

usort($packages, fn(array $a, array $b): int => [$a['priority'], $a['name']] <=> [$b['priority'], $b['name']]);

foreach ($packages as $package) {
	try {
		installPackageResources(
			$package['name'],
			$package['path'],
			$destinationRoot,
			$allowLibraryInstall,
			$packageConfig[$package['name']] ?? [],
			'replace',
		);

	} catch (Throwable $e) {
		message("Error in {$package['name']}: " . $e->getMessage(), "{$red}ERROR:{$reset}", true);
		continue;
	}
}
if (!$isDevMode) {
	markInstallOncePackages($rootComposerPath, $rootComposer, $installOncePackages);
}

echo "{$green}OK Finished ({$stats['copied']} copied, {$stats['skipped']} skipped, {$stats['errors']} errors){$reset}\n";
