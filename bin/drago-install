#!/usr/bin/env php
<?php

declare(strict_types=1);

use Composer\InstalledVersions;

// Try to find composer's autoload
$autoloadPaths = [
		getcwd() . '/vendor/autoload.php',
		__DIR__ . '/../../../autoload.php',
		__DIR__ . '/../vendor/autoload.php',
];

$autoloadFound = false;
foreach ($autoloadPaths as $path) {
	if (file_exists($path)) {
		require $path;
		$autoloadFound = true;
		break;
	}
}

if (!$autoloadFound) {
	die("ERROR: composer autoload.php not found. Run 'composer install' first.\n");
}

$projectRoot = getcwd();

/**
 * PARAMETERS:
 * --verbose / -v : prints detailed information about copying
 * --dev          : switches the destination directory to resources/ for testing during package development
 */
$verbose = in_array('--verbose', $argv) || in_array('-v', $argv);
$isDevMode = in_array('--dev', $argv);

// If we are in dev mode, the target is not the project root, but the resources folder in the current package
$destinationRoot = $isDevMode ? $projectRoot . '/resources' : $projectRoot;

$stats = ['copied' => 0, 'skipped' => 0, 'errors' => 0];
$installOncePackages = [];

function message(string $msg, string $icon = '', bool $force = false): void
{
	global $verbose;
	if ($verbose || $force) {
		echo $icon . ' ' . $msg . "\n";
	}
}

function ensureDir(string $dir): void
{
	if (!is_dir($dir) && !mkdir($dir, 0o777, true) && !is_dir($dir)) {
		throw new RuntimeException("Cannot create directory: $dir");
	}
}

function copyFile(string $source, string $destination, bool $overwrite = false): void
{
	global $stats;

	$existsBefore = file_exists($destination);
	ensureDir(dirname($destination));

	if (!$overwrite && $existsBefore) {
		message($destination, 'SKIP exists:');
		$stats['skipped']++;
		return;
	}

	if (!copy($source, $destination)) {
		$stats['errors']++;
		throw new RuntimeException("Failed copying $source -> $destination");
	}

	$stats['copied']++;
	$icon = ($overwrite && $existsBefore) ? 'REPLACED:' : 'COPIED:';
	message("$source -> $destination", $icon);
}

function recursiveCopy(string $source, string $destination, bool $overwrite = false): void
{
	$iterator = new RecursiveIteratorIterator(
			new RecursiveDirectoryIterator($source, FilesystemIterator::SKIP_DOTS),
			RecursiveIteratorIterator::SELF_FIRST
	);

	foreach ($iterator as $item) {
		$targetPath = $destination . '/' . substr($item->getPathname(), strlen($source) + 1);
		if ($item->isDir()) {
			ensureDir($targetPath);
		} else {
			copyFile($item->getPathname(), $targetPath, $overwrite);
		}
	}
}

function installPackageResources(
	string $packageName,
	string $packagePath,
	string $targetBaseDir,
	bool $allowLibraryInstall,
	array $packageOptions,
	?string $onlySection = null,
): void
{
	global $stats, $installOncePackages;

	$composerPath = $packagePath . '/composer.json';
	if (!is_file($composerPath)) return;

	$composer = json_decode(file_get_contents($composerPath), true);
	$dragoConfig = $composer['extra']['drago-project'] ?? [];
	$install = $dragoConfig['install'] ?? [];
	$sections = ['copy' => false, 'replace' => true];

	$type = $composer['type'] ?? 'library';
	if ($type === 'library' && !$allowLibraryInstall && (!empty($install['copy']) || !empty($install['replace']))) {
		return;
	}

	$hasReplace = !empty($install['replace']);
	$errorsBefore = $stats['errors'];

	foreach ($sections as $sectionName => $overwrite) {
		if ($onlySection !== null && $sectionName !== $onlySection) {
			continue;
		}

		if (($packageOptions['skip-' . $sectionName] ?? false) === true) {
			message("Skipping $sectionName section: $packageName", '[skip]', true);
			continue;
		}

		$items = $install[$sectionName] ?? null;
		if (!$items) continue;

		foreach ($items as $srcRel => $dstRel) {
			$source = $packagePath . '/' . $srcRel;

			if (!file_exists($source)) {
				message($source, 'ERROR source not found:');
				$stats['errors']++;
				continue;
			}

			$destination = $dstRel === ''
					? $targetBaseDir . '/' . basename($source)
					: $targetBaseDir . '/' . $dstRel;

			if (is_file($source)) {
				if (is_dir($destination) || (!pathinfo($destination, PATHINFO_EXTENSION) && !file_exists($destination))) {
					ensureDir($destination);
					$destination .= '/' . basename($source);
				}
				copyFile($source, $destination, $overwrite);

			} elseif (is_dir($source)) {
				recursiveCopy($source, $destination, $overwrite);
			}
		}
	}

	if (
		($onlySection === null || $onlySection === 'replace')
		&& ($dragoConfig['install-once'] ?? false) === true
		&& $hasReplace
		&& $stats['errors'] === $errorsBefore
	) {
		$installOncePackages[] = $packageName;
	}
}

function getPackagePriority(string $packagePath): int
{
	$composerPath = $packagePath . '/composer.json';
	if (!is_file($composerPath)) {
		return 100;
	}

	$composer = json_decode(file_get_contents($composerPath), true);
	return (int) ($composer['extra']['drago-project']['priority'] ?? 100);
}

function writeRootComposer(string $rootComposerPath, array $rootComposer): void
{
	$json = json_encode($rootComposer, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE);
	if ($json === false) {
		throw new RuntimeException('Cannot encode root composer.json.');
	}

	file_put_contents($rootComposerPath, $json . "\n");
}

function markInstallOncePackages(string $rootComposerPath, array $rootComposer, array $packageNames): void
{
	if ($packageNames === []) {
		return;
	}

	$changed = false;
	foreach (array_unique($packageNames) as $packageName) {
		$current = $rootComposer['extra']['drago-project']['packages'][$packageName]['skip-replace'] ?? false;
		if ($current === true) {
			continue;
		}

		$rootComposer['extra']['drago-project']['packages'][$packageName]['skip-replace'] = true;
		$changed = true;
		message("Marked package replace section as install-once: $packageName", '[once]', true);
	}

	if ($changed) {
		writeRootComposer($rootComposerPath, $rootComposer);
	}
}

// ----------------------------
// ROOT CONFIG
// ----------------------------
$rootComposerPath = $projectRoot . '/composer.json';
if (!file_exists($rootComposerPath)) {
	die("ERROR: composer.json not found in current directory.\n");
}

$rootComposer = json_decode(file_get_contents($rootComposerPath), true);

$dragoConfig = $rootComposer['extra']['drago-project'] ?? [];
$allowLibraryInstall = $dragoConfig['allow-library-install'] ?? false;
$packageConfig = $dragoConfig['packages'] ?? [];

$rootPackageName = InstalledVersions::getRootPackage()['name'] ?? null;

if ($isDevMode) {
	message("Dev mode active: redirecting output to $destinationRoot", 'DEV:', true);
}

// ----------------------------
// MAIN LOOP
// ----------------------------
$packages = [];
foreach (InstalledVersions::getInstalledPackages() as $packageName) {

	if ($packageName === 'drago-ex/project-installer') continue;

	// Skip root package
	if ($packageName === $rootPackageName) {
		continue;
	}

	// Skip packages via composer.json config
	if (($packageConfig[$packageName]['skip'] ?? false) === true) {
		message("Skipping package (config): $packageName", '[skip]', true);
		continue;
	}

	$packagePath = InstalledVersions::getInstallPath($packageName);
	if (!$packagePath) {
		continue;
	}

	$packages[] = [
		'name' => $packageName,
		'path' => $packagePath,
		'priority' => getPackagePriority($packagePath),
	];
}

foreach ($packages as $package) {
	try {
		installPackageResources(
			$package['name'],
			$package['path'],
			$destinationRoot,
			$allowLibraryInstall,
			$packageConfig[$package['name']] ?? [],
			'copy',
		);

	} catch (Throwable $e) {
		message("Error in {$package['name']}: " . $e->getMessage(), 'ERROR:', true);
		continue;
	}
}

usort($packages, fn(array $a, array $b): int => [$a['priority'], $a['name']] <=> [$b['priority'], $b['name']]);

foreach ($packages as $package) {
	try {
		installPackageResources(
			$package['name'],
			$package['path'],
			$destinationRoot,
			$allowLibraryInstall,
			$packageConfig[$package['name']] ?? [],
			'replace',
		);

	} catch (Throwable $e) {
		message("Error in {$package['name']}: " . $e->getMessage(), 'ERROR:', true);
		continue;
	}
}
if (!$isDevMode) {
	markInstallOncePackages($rootComposerPath, $rootComposer, $installOncePackages);
}

echo "OK Finished ({$stats['copied']} copied, {$stats['skipped']} skipped, {$stats['errors']} errors)\n";

