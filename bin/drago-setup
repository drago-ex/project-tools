#!/usr/bin/env php
<?php

declare(strict_types=1);

use Composer\InstalledVersions;

$blue = "\033[34m";
$green = "\033[32m";
$yellow = "\033[33m";
$red = "\033[31m";
$reset = "\033[0m";
const ToolsExtraKey = 'drago-tools';
const DefaultVendorNames = ['drago-ex'];

$autoloadPaths = [
	getcwd() . '/vendor/autoload.php',
	__DIR__ . '/../../../autoload.php',
	__DIR__ . '/../vendor/autoload.php',
];

$autoloadFound = false;
foreach ($autoloadPaths as $path) {
	if (is_file($path)) {
		require $path;
		$autoloadFound = true;
		break;
	}
}

if (!$autoloadFound) {
	die("{$red}ERROR: composer autoload.php not found. Run 'composer install' first.{$reset}\n");
}

function normalizeVendorNames(mixed $vendorNames): array
{
	if (is_string($vendorNames) && $vendorNames !== '') {
		$vendorName = trim($vendorNames, '/');
		assertSafeVendorName($vendorName);
		return [$vendorName];
	}

	if (!is_array($vendorNames)) {
		return DefaultVendorNames;
	}

	$normalized = [];
	foreach ($vendorNames as $vendorName) {
		if (is_string($vendorName) && $vendorName !== '') {
			$vendorName = trim($vendorName, '/');
			assertSafeVendorName($vendorName);
			$normalized[] = $vendorName;
		}
	}

	return $normalized !== [] ? array_values(array_unique($normalized)) : DefaultVendorNames;
}

function assertSafeVendorName(string $vendorName): void
{
	if (preg_match('~^[a-z0-9][a-z0-9._-]*$~', $vendorName) !== 1) {
		throw new RuntimeException("Unsafe vendor name: $vendorName");
	}
}

function isAllowedVendor(string $packageName, array $vendorNames): bool
{
	foreach ($vendorNames as $vendorName) {
		if (str_starts_with($packageName, $vendorName . '/')) {
			return true;
		}
	}

	return false;
}

function warnMissingVendorNames(string $projectRoot, array $vendorNames): void
{
	global $yellow, $reset;

	foreach ($vendorNames as $vendorName) {
		if (!is_dir($projectRoot . '/vendor/' . $vendorName)) {
			echo "{$yellow}WARN Vendor name not found: {$vendorName}{$reset}\n";
		}
	}
}

function normalizeSetupCommand(mixed $command): ?string
{
	if (is_string($command)) {
		return $command;
	}

	if (!is_array($command)) {
		return null;
	}

	$run = $command['run'] ?? $command['command'] ?? $command['bin'] ?? null;
	if (!is_string($run) || $run === '') {
		return null;
	}

	return $run;
}

/** @param array<string, array{priority: int}> $commands */
function sortSetupCommands(array $commands): array
{
	uksort($commands, static function (string $a, string $b) use ($commands): int {
		$isDbA = str_starts_with($a, 'db:');
		$isDbB = str_starts_with($b, 'db:');

		if ($isDbA && !$isDbB) {
			return -1;
		}

		if (!$isDbA && $isDbB) {
			return 1;
		}

		$priorityA = $commands[$a]['priority'];
		$priorityB = $commands[$b]['priority'];

		if ($priorityA !== $priorityB) {
			return $priorityA <=> $priorityB;
		}

		return strcmp($a, $b);
	});

	return $commands;
}

$availableCommands = [];
$projectRoot = getcwd();
$rootComposerPath = $projectRoot . '/composer.json';
if (!is_file($rootComposerPath)) {
	die("{$red}ERROR: composer.json not found in current directory.{$reset}\n");
}

$rootComposer = json_decode((string) file_get_contents($rootComposerPath), true);
if (!is_array($rootComposer)) {
	die("{$red}ERROR: composer.json is not valid JSON.{$reset}\n");
}

$rootConfig = $rootComposer['extra'][ToolsExtraKey] ?? [];
if (!is_array($rootConfig)) {
	$rootConfig = [];
}

$vendorNames = normalizeVendorNames($rootConfig['vendor-names'] ?? DefaultVendorNames);
warnMissingVendorNames($projectRoot, $vendorNames);

foreach (InstalledVersions::getInstalledPackages() as $packageName) {
	if (!isAllowedVendor($packageName, $vendorNames)) {
		continue;
	}

	$path = InstalledVersions::getInstallPath($packageName);
	if (!$path || !is_file($path . '/composer.json')) {
		continue;
	}

	$composer = json_decode((string) file_get_contents($path . '/composer.json'), true);
	if (!is_array($composer)) {
		continue;
	}

	$extra = $composer['extra'][ToolsExtraKey] ?? [];
	if (!is_array($extra)) {
		continue;
	}

	$commands = $extra['commands'] ?? [];
	if (!is_array($commands)) {
		continue;
	}

	$packagePriority = (int) ($extra['commands-priority'] ?? 100);

	foreach ($commands as $label => $command) {
		if (!is_string($label)) {
			continue;
		}

		$normalized = normalizeSetupCommand($command);
		if ($normalized === null) {
			echo "{$yellow}WARN Invalid setup command '{$label}' in {$packageName}.{$reset}\n";
			continue;
		}

		$availableCommands[$label] = [
			'run' => $normalized,
			'package' => $packageName,
			'priority' => $packagePriority,
		];
	}
}

if ($availableCommands === []) {
	echo "{$yellow}WARN No available setup commands found.{$reset}\n";
	exit;
}

$availableCommands = sortSetupCommands($availableCommands);

echo "Available operations for the current package setup:\n\n";

$index = 1;
$map = [];

foreach ($availableCommands as $label => $data) {
	printf(
		"  [%2d] %-30s %s(%s)%s\n",
		$index,
		$label,
		$blue,
		$data['package'],
		$reset
	);

	$map[$index] = [
		'run' => $data['run'],
		'label' => $label,
	];

	$index++;
}

echo "\n  [ a] Run ALL (sequential)";
echo "\n  [ q] Quit\n";
echo "------------------------------------------\n";

if (isset($argv[1])) {
	$input = trim((string) $argv[1]);
	echo "{$blue}INFO Running with arguments:{$reset} {$input}\n";
} else {
	echo 'Select numbers (e.g., 1,3) or action: ';
	$handle = fopen('php://stdin', 'r');
	$line = $handle ? fgets($handle) : false;
	if ($handle) {
		fclose($handle);
	}

	$input = $line ? trim($line) : '';
}

if ($input === '' || $input === 'q') {
	echo "{$blue}INFO Exiting...{$reset}\n";
	exit;
}

$choices = $input === 'a'
	? array_keys($map)
	: explode(',', $input);

foreach ($choices as $choice) {
	$choice = trim((string) $choice);

	if (!is_numeric($choice) || !isset($map[(int) $choice])) {
		if ($choice !== '') {
			echo "{$red}WARN Invalid selection: {$choice}{$reset}\n";
		}

		continue;
	}

	$command = $map[(int) $choice];

	echo "\n{$blue}INFO Executing: {$command['label']}{$reset}\n";
	echo "{$yellow}{$command['run']}{$reset}\n";

	$returnCode = 0;

	passthru($command['run'], $returnCode);

	if ($returnCode !== 0) {
		echo "{$red}ERROR Command failed with exit code {$returnCode}.{$reset}\n";
	}
}

echo "\n{$green}OK Done.{$reset}\n";
